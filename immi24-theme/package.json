{
  "name": "immi24-theme",
  "version": "1.0.0",
  "description": "Tailwind build setup for Immi24 WordPress theme",
  "scripts": {
    "build:css": "tailwindcss -i ./input.css -o ./assets/css/tailwind-output.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./assets/css/tailwind-output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/container-queries": "^0.1.1"
  }
}
